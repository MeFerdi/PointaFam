---
import logo from '../images/pointafam-logo.png'
export interface Props {
  backgroundColor?: string; // Add backgroundColor prop
}

const { backgroundColor } = Astro.props as Props;
---

<section class="showcase" style={`background-color: ${backgroundColor || '#7CB342'}`}> <!-- Default to green color -->
  <div class="container">
    <div class="showcase-text">
      <img src={logo} alt="PointaFam Logo" class="logo" />
      <h1>Welcome to PointaFam!</h1>
      <p>
        Connect farmers with urban retailers and revolutionize the way fresh produce is sourced and distributed.
      </p>
    </div>

    <p class="showcase-demo">
      <small>This is a demo website used for showcasing the PointaFam platform.</small>
    </p>
  </div>
</section>

<style>
  .showcase {
    padding: 50px 0;
    text-align: center;
    background-size: cover;
    background-position: center;
  }

  .showcase .container {
    max-width: 800px;
    margin: 0 auto;
  }

  .showcase .logo {
    width: 100px;
    height: 100px;
    margin-bottom: 20px;
  }

  .showcase h1 {
    color: #fff;
    font-size: 36px;
    margin-bottom: 20px;
  }

  .showcase p {
    color: #fff;
    font-size: 18px;
    margin-bottom: 20px;
  }

  .showcase-demo {
    color: #fff;
    font-size: 14px;
    font-weight: 300;
  }
</style>
