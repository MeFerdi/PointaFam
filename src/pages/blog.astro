<!-- src/pages/Blog.astro -->

---
title: Blog
layout: layouts/default.astro
---

<template>
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-4">Latest Blog Posts</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <template x-for="post in blogPosts" :key="post.id">
        <div class="bg-white shadow-md rounded-md p-4">
          <h2 class="text-xl font-semibold mb-2">{{ post.title }}</h2>
          <p class="text-gray-500 mb-4">{{ post.excerpt }}</p>
          <p class="text-sm text-gray-400">{{ formatDate(post.date) }}</p>
        </div>
      </template>
    </div>
  </div>
</template>

<script setup>
import { reactive, onMounted } from 'vue';

const state = reactive({
  blogPosts: [],
});

const fetchBlogPosts = async () => {
  try {
    const response = await fetch('your-pocketbase-api-endpoint');
    const data = await response.json();
    state.blogPosts = data.posts; // Assuming your API response contains a list of posts
  } catch (error) {
    console.error('Error fetching blog posts:', error);
  }
};

const formatDate = (dateString) => {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};

onMounted(() => {
  fetchBlogPosts();
});
</script>
