---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import logos from '../images/pngegg.png';
import logosSmall from '../images/pngegg.png';
---

<div class="container">

 <template>
  <div class="container mx-auto px-4 py-8">
    <h1>Welcome to the Farmers Page</h1>
    <p>This page connects farmers producing perishable but essential products with retailers in need of these goods for resell.</p>
    
    <!-- Farmer Registration Form -->
    <div class="registration-form">
      <h2>Register as a Farmer</h2>
      <form action="/register" method="post">
        <label for="name">Name:</label>
        <input type="text" id="name" name="name" required>
        <br>
        <label for="location">Location:</label>
        <input type="text" id="location" name="location" required>
        <br>
        <label for="contacts">Contacts:</label>
        <input type="text" id="contacts" name="contacts" required>
        <br>
        <label for="product">Product:</label>
        <input type="text" id="product" name="product" required>
        <br>
        <label for="price">Price:</label>
        <input type="text" id="price" name="price" required>
        <br>
        <button type="submit">Register</button>
      </form>
    </div>
    
    <!-- Farmer Details -->
    <div class="farmer">
      <h2>Farmer 1</h2>
      <p>Location: Nairobi, Kenya</p>
      <p>Contacts: +254-XXXXXXX | farmer1@example.com</p>
      
      <!-- Product Listings -->
      <h3>Product Listings</h3>
      <ul>
        <li>Product: Onions | Price: $10/kg</li>
        <li>Product: Tomatoes | Price: $15/kg</li>
        <!-- Add more product listings for Farmer 1 -->
      </ul>
    </div>
    
</template>

<style>
  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 20px;
  }

  .registration-form {
    margin-bottom: 30px;
  }

  .farmer {
    margin-bottom: 30px;
    padding: 20px;
    border: 1px solid #ccc;
    border-radius: 5px;
  }

  .farmers-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }

  .farmers img {
    max-width: 100%;
    height: auto;
    border-radius: 5px;
  }

  .farmers-list.bg-blue-500 {
    background-color: #4a90e2; /* Adjust color as needed */
    color: #fff;
  }
</style>