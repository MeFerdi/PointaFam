---
import Layout from '../layouts/Layout.astro';
import FarmerCard from '../components/FarmerCard.astro'; // Import FarmerCard component
---

<Layout title="PointaFam - Meet Our Farmers">
  <section class="page-content container mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-8">Meet Our Dedicated Farmers</h1>
    <p class="text-xl mb-12">
      PointaFam connects you with passionate and sustainable farmers who are committed to providing fresh, high-quality produce. Explore the profiles below to learn more about their farms and the delicious products they offer.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {farmers.map((farmer) => (
        <FarmerCard
          key={farmer.name} // Unique key for each card
          name={farmer.name}
          location={farmer.location}
          description={farmer.description}
          image={farmer.image}
          website={farmer.website} // Optional website link
        />
      ))}
    </div>

    <p class="text-center mt-12">
      Interested in joining our network of farmers?
      <a href="/become-a-farmer" class="text-green-500 underline">Learn More</a> or
      <a href="/signup" class="text-green-500 underline font-bold">Sign Up Now</a>
    </p>
  </section>
</Layout>
