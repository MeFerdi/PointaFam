---
const retailers = [
  {
    name: "Retailer 1",
    location: "City A",
    description: "Fruit vendor and sells also fresh vegetables.",
    image: "/images/frame2-logo.jpg"
  },
  {
    name: "Retailer 2",
    location: "City B",
    description: "A friendly customer.",
    image: "/images/frame-logo.jpg"
  },
];
---

<section class="retailers">
  <div class="container">
    <h2>Our Retailers</h2>
    <div class="retailers-list">
      {retailers.map(retailer => (
        <div class="retailer">
          <img src={retailer.image} alt={retailer.name} />
          <div class="details">
            <h3>{retailer.name}</h3>
            <p>{retailer.location}</p>
            <p>{retailer.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .retailers {
    padding: 20px;
  }

  .retailers h2 {
    text-align: center;
    margin-bottom: 20px;
  }

  .retailers-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }

  .retailer {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 20px;
    border: 1px solid #ccc;
    border-radius: 5px;
  }

  .retailer img {
    width: 100%;
    max-width: 200px;
    border-radius: 5px;
  }

  .retailer .details {
    margin-top: 10px;
  }

  .retailer h3 {
    margin-bottom: 5px;
  }
</style>
