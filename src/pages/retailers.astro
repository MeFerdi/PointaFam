---
import { Meta } from '@astro/components'
---
<div class="container">

  <h1>Urban Marketplace - Retailers page</h1>
  
  <!-- Retailer Details -->
  <div class="retailer">
    <h2>Retailer 1</h2>
    <p>Location: Nairobi, Kenya</p>
    <p>Contacts: +254-XXXXXXX | retailer1@example.com</p>
    <p>Type of Retailer: Fashion</p>
  </div>

  <div class="retailer">
    <h2>Retailer 2</h2>
    <p>Location: Nairobi, Kenya</p>
    <p>Contacts: +254-XXXXXXX | retailer2@example.com</p>
    <p>Type of Retailer: Electronics</p>
  </div>

  <div class="retailer">
    <h2>Retailer 3</h2>
    <p>Location: Nairobi, Kenya</p>
    <p>Contacts: +254-XXXXXXX | retailer3@example.com</p>
    <p>Type of Retailer: Food & Groceries</p>
  </div>

  <div class="retailer">
    <h2>Retailer 4</h2>
    <p>Location: Nairobi, Kenya</p>
    <p>Contacts: +254-XXXXXXX | retailer4@example.com</p>
    <p>Type of Retailer: Home Appliances</p>
  </div>
</div>

<style>
  .retailers {
    padding: 20px;
  }

  .retailers h2 {
    text-align: center;
    margin-bottom: 20px;
  }

  .retailers-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }

  .retailer {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 20px;
    border: 1px solid #ccc;
    border-radius: 5px;
  }

  .retailer img {
    width: 100%;
    max-width: 200px;
    border-radius: 5px;
  }

  .retailer .details {
    margin-top: 10px;
  }

  .retailer h3 {
    margin-bottom: 5px;
  }
</style>
